<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
    <!-- Grupo de administardor con control completo del módulo. -->
    <record id="group_tourney_admin" model="res.groups">
        <field name="name">Administrador de Torneos</field>
    </record>

    <!-- Grupo de organizador operativo para gestión de torneos. -->
    <record id="group_tourney_organizer" model="res.groups">
        <field name="name">Organizador</field>
    </record>

    <!-- Grupo de participamte con acceso restringido para jugadores/equipos inscritos. -->
    <record id="group_tourney_participant" model="res.groups">
        <field name="name">Participante</field>
    </record>
    </data>
</odoo>