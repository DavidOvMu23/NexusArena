<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas base del modelo esports.game (videojuegos). -->

    <!-- Vista de lista para consultar los videojuegos. -->
    <record id="view_esports_game_list" model="ir.ui.view"> <!-- ir.ui.view indica a odoo que lo que estamos haciendo es una vista-->
        <field name="name">esports.game.list</field>
        <field name="model">esports.game</field>
        <field name="arch" type="xml">
            <list string="Videojuegos">
                <field name="nombre"/>
                <field name="genero"/>
                <field name="modalidad"/>
                <field name="desarrollador"/>
                <field name="max_jugadores_equipo"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para crear/editar un videojuego. -->
    <record id="view_esports_game_form" model="ir.ui.view">
        <field name="name">esports.game.form</field>
        <field name="model">esports.game</field>
        <field name="arch" type="xml">
            <form string="Videojuego">
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="genero"/>
                            <field name="modalidad"/>
                        </group>
                        <group>
                            <field name="desarrollador"/>
                            <field name="max_jugadores_equipo"/>
                            <field name="imagen" widget="image" class="oe_avatar"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda con filtros por género y modalidad. -->
    <record id="view_esports_game_search" model="ir.ui.view">
        <field name="name">esports.game.search</field>
        <field name="model">esports.game</field>
        <field name="arch" type="xml">
            <search string="Buscar Videojuegos">
                <field name="nombre"/>
                <field name="desarrollador"/>
                <field name="genero"/>
                <field name="modalidad"/>
                <filter string="MOBA" name="filter_genero_moba" domain="[('genero', '=', 'moba')]"/>
                <filter string="FPS" name="filter_genero_fps" domain="[('genero', '=', 'fps')]"/>
                <separator/>
                <filter string="Individual" name="filter_modalidad_individual" domain="[('modalidad', '=', 'individual')]"/>
                <filter string="Equipos" name="filter_modalidad_teams" domain="[('modalidad', '=', 'teams')]"/>
            </search>
        </field>
    </record>

    <!-- Acción para abrir la vista de videojuegos -->
    <record id="action_esports_game" model="ir.actions.act_window"> <!-- ir.actions.act_window indica a odoo que lo que estamos haciendo es una acción de ventana-->
        <field name="name">Videojuegos</field>
        <field name="res_model">esports.game</field> <!--indicamos el modelo-->
        <field name="view_mode">list,form</field> <!--indicamos los modos de vista disponibles-->
        <field name="search_view_id" ref="view_esports_game_search"/> <!--referenciamos la vista de búsqueda personalizada-->
    </record>

    <record id="action_esports_game_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_game_list"/>
        <field name="act_window_id" ref="action_esports_game"/>
    </record>

    <record id="action_esports_game_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_game_form"/>
        <field name="act_window_id" ref="action_esports_game"/>
    </record>
</odoo>