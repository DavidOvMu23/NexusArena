<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas base del modelo esports.registration (inscripciones). -->

    <!-- Vista de lista para ver las inscripciones. -->
    <record id="view_esports_registration_list" model="ir.ui.view"> <!-- ir.ui.view indica a odoo que lo que estamos haciendo es una vista-->
        <field name="name">esports.registration.list</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <list string="Inscripciones">
                <field name="fecha_inscripcion"/>
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Vista kanban para las inscripciones. -->
    <record id="view_esports_registration_kanban" model="ir.ui.view">
        <field name="name">esports.registration.kanban</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <kanban string="Inscripciones">
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="fecha_inscripcion"/>
                <field name="state"/>
                <templates>
                    <t t-name="card">
                        <main class="o_kanban_card_content">
                            <div class="mb-1"> 
                                <strong><field name="participante_id"/></strong>
                            </div>
                            <div class="text-muted mb-1">
                                <field name="torneo_id"/>
                            </div>
                            <div>
                                <strong>Fecha:</strong>
                                <field name="fecha_inscripcion"/>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista de formulario para alta/edición de inscripciones. -->
    <record id="view_esports_registration_form" model="ir.ui.view">
        <field name="name">esports.registration.form</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <form string="Inscripción">

            

                <!-- Botones de acción en el encabezado -->
                <header>
                    <button name="action_confirm_registration" type="object" string="Confirmar inscripción" class="oe_highlight" invisible="state != 'pending'"/> <!-- El botón solo se muestra si el estado es 'pending' -->
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="torneo_id"/>
                            <field name="participante_id"/>
                        </group>
                        <group>
                            <field name="fecha_inscripcion"/>
                            <field name="state" widget="statusbar" statusbar_visible="pending,confirmed,disqualified"/> <!-- hacemos que el statusbar sea visible haciendo visible en todos los estados -->



                            <!-- Campos calculados -->
                            <field name="dias_desde_inscripcion" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda con filtros por state de inscripción. -->
    <record id="view_esports_registration_search" model="ir.ui.view">
        <field name="name">esports.registration.search</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <search string="Buscar Inscripciones">
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="state"/>
                <field name="fecha_inscripcion"/>
                <filter string="Pendiente" name="filter_state_pending" domain="[('state', '=', 'pending')]"/> <!-- Filtro para mostrar solo inscripciones pendientes -->
                <filter string="Confirmada" name="filter_state_confirmed" domain="[('state', '=', 'confirmed')]"/> <!-- Filtro para mostrar solo inscripciones confirmadas -->
                <filter string="Descalificada" name="filter_state_disqualified" domain="[('state', '=', 'disqualified')]"/> <!-- Filtro para mostrar solo inscripciones descalificadas -->
                <separator/>
                <filter string="Agrupar por state" name="group_by_state" context="{'group_by': 'state'}"/> <!-- Opción para agrupar por estado de inscripción -->
            </search>
        </field>
    </record>

    <!-- Estas son las distintas acciones para cambiar entre los tipos de vistas-->
    <record id="action_esports_registration" model="ir.actions.act_window"> <!-- ir.actions.act_window indica a odoo que lo que estamos haciendo es una acción de ventana-->
        <field name="name">Inscripciones</field> <!--nombre de la acción que aparecerá en el menú-->
        <field name="res_model">esports.registration</field> <!--indicamos el modelo al que se aplicará la acción-->
        <field name="view_mode">kanban,list,form</field> <!--indicamos los modos de vista disponibles-->
        <field name="search_view_id" ref="view_esports_registration_search"/> <!--referenciamos la vista de búsqueda personalizada para inscripciones-->
        <field name="context">{'search_default_group_by_state': 1}</field> <!-- Hacemos que por defecto se agrupe por estado de inscripción al abrir la vista-->
    </record>

    <record id="action_esports_registration_kanban_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_esports_registration_kanban"/>
        <field name="act_window_id" ref="action_esports_registration"/>
    </record>

    <record id="action_esports_registration_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_registration_list"/>
        <field name="act_window_id" ref="action_esports_registration"/>
    </record>

    <record id="action_esports_registration_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_registration_form"/>
        <field name="act_window_id" ref="action_esports_registration"/>
    </record>
</odoo>