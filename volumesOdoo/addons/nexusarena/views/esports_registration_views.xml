<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- Estas son las vistas para las inscripciones de esports -->
    <record id="view_esports_registration_list" model="ir.ui.view">
        <field name="name">esports.registration.list</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <list string="Inscripciones">
                <field name="fecha_inscripcion"/>
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para las inscripciones -->
    <record id="view_esports_registration_form" model="ir.ui.view">
        <field name="name">esports.registration.form</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <form string="Inscripción">
                <sheet>
                    <group>
                        <group>
                            <field name="torneo_id"/>
                            <field name="participante_id"/>
                        </group>
                        <group>
                            <field name="fecha_inscripcion"/>
                            <field name="estado"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

        <!-- Vista de búsqueda para las inscripciones -->
    <record id="view_esports_registration_search" model="ir.ui.view">
        <field name="name">esports.registration.search</field>
        <field name="model">esports.registration</field>
        <field name="arch" type="xml">
            <search string="Buscar Inscripciones">
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="estado"/>
                <field name="fecha_inscripcion"/>
                <filter string="Pendiente" name="filter_estado_pending" domain="[('estado', '=', 'pending')]"/>
                <filter string="Confirmada" name="filter_estado_confirmed" domain="[('estado', '=', 'confirmed')]"/>
                <filter string="Descalificada" name="filter_estado_disqualified" domain="[('estado', '=', 'disqualified')]"/>
            </search>
        </field>
    </record>

    <!-- Estas son las distintas acciones para cambiar entre los tipos de vistas-->
    <record id="action_esports_registration" model="ir.actions.act_window">
        <field name="name">Inscripciones</field>
        <field name="res_model">esports.registration</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esports_registration_search"/>
    </record>

    <record id="action_esports_registration_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_registration_list"/>
        <field name="act_window_id" ref="action_esports_registration"/>
    </record>

    <record id="action_esports_registration_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_registration_form"/>
        <field name="act_window_id" ref="action_esports_registration"/>
    </record>
</odoo>