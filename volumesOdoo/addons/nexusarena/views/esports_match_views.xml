<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- Estas son las vistas para las partidas de esports -->
    <record id="view_esports_match_list" model="ir.ui.view">
        <field name="name">esports.match.list</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <list string="Partidas">
                <field name="torneo_id"/>
                <field name="fase"/>
                <field name="fecha_hora_programada"/>
                <field name="participante_local"/>
                <field name="participante_visitante"/>
                <field name="estado"/>
                <field name="puntuacion_local"/>
                <field name="puntuacion_visitante"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para las partidas -->
    <record id="view_esports_match_form" model="ir.ui.view">
        <field name="name">esports.match.form</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <form string="Partida">
                <sheet>
                    <group>
                        <group>
                            <field name="torneo_id"/>
                            <field name="fase"/>
                            <field name="estado"/>
                            <field name="fecha_hora_programada"/>
                        </group>
                        <group>
                            <field name="participante_local"/>
                            <field name="participante_visitante"/>
                            <field name="puntuacion_local"/>
                            <field name="puntuacion_visitante"/>
                            <field name="resultado"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para las partidas -->
    <record id="view_esports_match_search" model="ir.ui.view">
        <field name="name">esports.match.search</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <search string="Buscar Partidas">
                <field name="torneo_id"/>
                <field name="participante_local"/>
                <field name="participante_visitante"/>
                <field name="estado"/>
                <field name="fase"/>
                <filter string="Programada" name="filter_estado_scheduled" domain="[('estado', '=', 'scheduled')]"/>
                <filter string="En Juego" name="filter_estado_playing" domain="[('estado', '=', 'playing')]"/>
                <filter string="Finalizada" name="filter_estado_finished" domain="[('estado', '=', 'finished')]"/>
                <filter string="Walkover" name="filter_estado_walkover" domain="[('estado', '=', 'walkover')]"/>
            </search>
        </field>
    </record>

    <!-- Acción para abrir la vista de partidas -->
    <record id="action_esports_match" model="ir.actions.act_window">
        <field name="name">Partidas</field>
        <field name="res_model">esports.match</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esports_match_search"/>
    </record>

    <record id="action_esports_match_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_match_list"/>
        <field name="act_window_id" ref="action_esports_match"/>
    </record>

    <record id="action_esports_match_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_match_form"/>
        <field name="act_window_id" ref="action_esports_match"/>
    </record>
</odoo>