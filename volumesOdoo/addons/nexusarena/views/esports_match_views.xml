<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas base del modelo esports.match (partidas). -->

    <!-- Vista de lista para ver las partidas. -->
    <record id="view_esports_match_list" model="ir.ui.view"> <!-- ir.ui.view indica a odoo que lo que estamos haciendo es una vista-->
        <field name="name">esports.match.list</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <list string="Partidas" decoration-success="state == 'playing'"> <!-- Decoramos la fila si el estado es 'playing' -->
                <field name="torneo_id"/>
                <field name="fase"/>
                <field name="fecha_hora_programada"/>
                <field name="participante_local"/>
                <field name="participante_visitante"/>
                <field name="state" widget="badge" decoration-success="state == 'playing'"/> <!-- Mostramos el estado como una badge y decoramos la fila si está en juego -->
                <field name="puntuacion_local" readonly="state in ('finished', 'walkover')"/> <!-- Hacemos que el campo de puntuación local sea solo lectura si la partida está finalizada o es walkover -->
                <field name="puntuacion_visitante" readonly="state in ('finished', 'walkover')"/> <!-- Hacemos que el campo de puntuación visitante sea solo lectura si la partida está finalizada o es walkover --> 
            </list>
        </field>
    </record>

    <!-- Vista de formulario para las partidas -->
    <record id="view_esports_match_form" model="ir.ui.view">
        <field name="name">esports.match.form</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <form string="Partida">



                <!-- Botones de acción en el encabezado -->
                <header>
                    <button name="action_start_match" type="object" string="Iniciar partida" class="oe_highlight" invisible="state != 'scheduled'"/>
                    <button name="action_register_result" type="object" string="Registrar resultado" class="oe_highlight" invisible="state in ('finished', 'walkover')"/>
                    <field name="state" widget="statusbar" statusbar_visible="scheduled,playing,finished,walkover"/> <!-- barra de progreso de estados visible en el encabezado -->
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="torneo_id"/>
                            <field name="fase"/>
                            <field name="fecha_hora_programada"/>
                        </group>
                        <group>
                            <field name="participante_local"/>
                            <field name="participante_visitante"/>
                            <field name="puntuacion_local" readonly="state in ('finished', 'walkover')"/> <!-- Hacemos que el campo de puntuación local sea solo lectura si la partida está finalizada o es walkover -->
                            <field name="puntuacion_visitante" readonly="state in ('finished', 'walkover')"/> <!-- Hacemos que el campo de puntuación visitante sea solo lectura si la partida está finalizada o es walkover -->
                            <field name="resultado" readonly="state in ('finished', 'walkover')"/> <!-- Hacemos que el campo de resultado sea solo lectura si la partida está finalizada o es walkover -->



                            <!-- Campos calculados -->
                            <field name="ganador_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda con filtros por state de la partida. -->
    <record id="view_esports_match_search" model="ir.ui.view">
        <field name="name">esports.match.search</field>
        <field name="model">esports.match</field>
        <field name="arch" type="xml">
            <search string="Buscar Partidas">
                <field name="torneo_id"/>
                <field name="participante_local"/>
                <field name="participante_visitante"/>
                <field name="state"/>
                <field name="fase"/>
                <filter string="Programada" name="filter_state_scheduled" domain="[('state', '=', 'scheduled')]"/> <!-- Filtro para partidas programadas -->
                <filter string="En Juego" name="filter_state_playing" domain="[('state', '=', 'playing')]"/> <!-- Filtro para partidas en juego -->
                <filter string="Finalizada" name="filter_state_finished" domain="[('state', '=', 'finished')]"/> <!-- Filtro para partidas finalizadas -->
                <filter string="Walkover" name="filter_state_walkover" domain="[('state', '=', 'walkover')]"/> <!-- Filtro para partidas con walkover -->
            </search>
        </field>
    </record>

    <!-- Acción para abrir la vista de partidas -->
    <record id="action_esports_match" model="ir.actions.act_window"> <!-- ir.actions.act_window indica a odoo que lo que estamos haciendo es una acción de ventana-->
        <field name="name">Partidas</field> <!--nombre de la acción que aparecerá en el menú-->
        <field name="res_model">esports.match</field> <!--indicamos el modelo al que se aplicará la acción-->
        <field name="view_mode">list,form</field> <!--indicamos los modos de vista disponibles-->
        <field name="search_view_id" ref="view_esports_match_search"/> <!--referenciamos la vista de búsqueda personalizada para partidas-->
    </record>

    <record id="action_esports_match_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_match_list"/>
        <field name="act_window_id" ref="action_esports_match"/>
    </record>

    <record id="action_esports_match_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_match_form"/>
        <field name="act_window_id" ref="action_esports_match"/>
    </record>
</odoo>