<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!-- Estas son las vistas para los torneos de esports -->
    <record id="view_esports_tournament_list" model="ir.ui.view">
        <field name="name">esports.tournament.list</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <list string="Torneos">
                <field name="nombre"/>
                <field name="edicion"/>
                <field name="videojuego_id"/>
                <field name="formato"/>
                <field name="modalidad"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado"/>
                <field name="premio_total"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para los torneos -->
    <record id="view_esports_tournament_form" model="ir.ui.view">
        <field name="name">esports.tournament.form</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <form string="Torneo">
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="edicion"/>
                            <field name="videojuego_id"/>
                            <field name="estado"/>
                        </group>
                        <group>
                            <field name="formato"/>
                            <field name="modalidad"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                        </group>
                    </group>
                    <group>
                        <field name="cuota_inscripcion"/>
                        <field name="premio_total"/>
                        <field name="premio_1"/>
                        <field name="premio_2"/>
                        <field name="premio_3"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para los torneos -->
    <record id="view_esports_tournament_search" model="ir.ui.view">
        <field name="name">esports.tournament.search</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <search string="Buscar Torneos">
                <field name="nombre"/>
                <field name="videojuego_id"/>
                <field name="estado"/>
                <field name="formato"/>
                <filter string="Borrador" name="filter_estado_draft" domain="[('estado', '=', 'draft')]"/>
                <filter string="Inscripciones Abiertas" name="filter_estado_open" domain="[('estado', '=', 'open')]"/>
                <filter string="En Curso" name="filter_estado_ongoing" domain="[('estado', '=', 'ongoing')]"/>
                <filter string="Finalizado" name="filter_estado_done" domain="[('estado', '=', 'done')]"/>
                <separator/>
                <filter string="Con Videojuego" name="filter_videojuego_set" domain="[('videojuego_id', '!=', False)]"/>
                <filter string="Agrupar por Videojuego" name="group_by_videojuego" context="{'group_by': 'videojuego_id'}"/>
                <separator/>
                <filter string="Liga" name="filter_formato_league" domain="[('formato', '=', 'league')]"/>
                <filter string="Elim. Directa" name="filter_formato_direct" domain="[('formato', '=', 'direct')]"/>
                <filter string="Doble Elim." name="filter_formato_double" domain="[('formato', '=', 'double')]"/>
            </search>
        </field>
    </record>

    <!-- Estas son las distintas acciones para cambiar entre los tipos de vistas-->
    <record id="action_esports_tournament" model="ir.actions.act_window">
        <field name="name">Torneos</field>
        <field name="res_model">esports.tournament</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esports_tournament_search"/>
    </record>

    <record id="action_esports_tournament_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_tournament_list"/>
        <field name="act_window_id" ref="action_esports_tournament"/>
    </record>

    <record id="action_esports_tournament_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_tournament_form"/>
        <field name="act_window_id" ref="action_esports_tournament"/>
    </record>
</odoo>