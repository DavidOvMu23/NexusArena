<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas base del modelo esports.tournament (torneos). -->

    <!-- Vista de lista para ver los torneos. -->
    <record id="view_esports_tournament_list" model="ir.ui.view"> <!-- ir.ui.view indica a odoo que lo que estamos haciendo es una vista-->
        <field name="name">esports.tournament.list</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <list string="Torneos" decoration-muted="state == 'cancel'">
                <field name="nombre"/>
                <field name="edicion"/>
                <field name="videojuego_id"/>
                <field name="formato"/>
                <field name="modalidad"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="state" widget="badge" decoration-muted="state == 'cancel'"/> <!-- El widget badge muestra el estado con un estilo de etiqueta, y decoration-muted lo atenua si el estado es 'cancel' -->
                <field name="premio_total"/>
            </list>
        </field>
    </record>

    <!-- Vista kanban para los torneos -->
    <record id="view_esports_tournament_kanban" model="ir.ui.view">
        <field name="name">esports.tournament.kanban</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <kanban string="Torneos">
                <field name="nombre"/>
                <field name="videojuego_id"/>
                <field name="videojuego_imagen"/>
                <field name="state"/>
                <field name="inscripcion_ids"/>
                <templates> <!-- Aquí definimos la plantilla para cada tarjeta del kanban -->
                    <t t-name="card"> <!-- t-name="card" es el nombre de la plantilla que se usará para cada registro en la vista kanban -->
                        <main class="o_kanban_card_content"> 
                            <div class="d-flex align-items-center mb-2">
                                <field name="videojuego_imagen" widget="image" class="me-2" options="{'size': [48, 48]}"/>
                                <div>
                                    <strong><field name="nombre"/></strong>
                                    <div class="text-muted"><field name="videojuego_id"/></div>
                                </div>
                            </div>
                            <div class="mb-1">
                                <strong>state:</strong>
                                <field name="state"/>
                            </div>
                            <div>
                                <strong>Participantes:</strong>
                                <!-- Aquí mostramos el número de inscripciones -->
                                <span t-esc="record.inscripcion_ids.raw_value.length"/>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vista de formulario para los torneos -->
    <record id="view_esports_tournament_form" model="ir.ui.view">
        <field name="name">esports.tournament.form</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <form string="Torneo">


                <!-- Botones de acción en el encabezado -->
                <header>
                    <button name="action_open_inscriptions" type="object" string="Abrir inscripciones" class="oe_highlight" invisible="state != 'draft'"/> <!-- El botón para abrir inscripciones solo se muestra si el estado es 'draft' -->
                    <button name="action_start_tournament" type="object" string="Iniciar torneo" invisible="state != 'open'"/> <!-- El botón para iniciar el torneo solo se muestra si el estado es 'open' -->
                    <button name="action_finalize_tournament" type="object" string="Finalizar torneo" invisible="state != 'ongoing'"/> <!-- El botón para finalizar el torneo solo se muestra si el estado es 'ongoing' -->
                    <button name="action_notify_participants" type="object" string="Notificar participantes" invisible="state in ('done', 'cancel')"/> <!-- El botón para notificar participantes solo se muestra si el estado no es 'done' ni 'cancel' -->
                    <button name="action_cancel_tournament" type="object" string="Cancelar torneo" confirm="¿Seguro que quieres cancelar el torneo?" invisible="state in ('done', 'cancel')"/> <!-- El botón para cancelar el torneo solo se muestra si el estado no es 'done' ni 'cancel', y muestra una confirmación antes de ejecutar la acción -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,ongoing,done"/> <!-- barra de progreso de estados visible en el encabezado -->
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="nombre"/>
                            <field name="edicion"/>
                            <field name="videojuego_id"/>
                            <field name="es_publico"/>
                        </group>
                        <group>
                            <field name="formato"/>
                            <field name="modalidad"/>
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                        </group>
                    </group>
                    <group>
                        <field name="cuota_inscripcion"/>
                        <field name="premio_total"/>
                        <field name="premio_1"/>
                        <field name="premio_2"/>
                        <field name="premio_3"/>
                    </group>

                    <!-- Campos calculados -->
                    <group>
                        <field name="inscripciones_count" readonly="1"/>
                        <field name="numero_participantes" readonly="1"/>
                        <field name="ingresos_totales" readonly="1"/>
                    </group>

                    <!-- Líneas de inscripción y partidas del torneo -->
                    <notebook>
                        <page string="Inscripciones">
                            <field name="inscripcion_ids">
                                <list>
                                    <field name="participante_id"/>
                                    <field name="fecha_inscripcion"/>
                                    <field name="state" widget="badge"/>
                                    <field name="dias_desde_inscripcion"/>
                                </list>
                            </field>
                        </page>
                        <page string="Partidas">
                            <field name="partida_ids">
                                <list>
                                    <field name="fase"/>
                                    <field name="fecha_hora_programada"/>
                                    <field name="participante_local"/>
                                    <field name="participante_visitante"/>
                                    <field name="puntuacion_local"/>
                                    <field name="puntuacion_visitante"/>
                                    <field name="ganador_id"/>
                                    <field name="state" widget="badge" decoration-success="state == 'playing'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Clasificación">
                            <field name="standing_ids">
                                <list>
                                    <field name="posicion_final"/>
                                    <field name="participante_id"/>
                                    <field name="partidas_jugadas"/>
                                    <field name="partidas_ganadas"/>
                                    <field name="partidas_perdidas"/>
                                    <field name="puntos_acumulados"/>
                                    <field name="premio_obtenido"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para los torneos -->
    <record id="view_esports_tournament_search" model="ir.ui.view">
        <field name="name">esports.tournament.search</field>
        <field name="model">esports.tournament</field>
        <field name="arch" type="xml">
            <search string="Buscar Torneos">
                <field name="nombre"/>
                <field name="videojuego_id"/>
                <field name="state"/>
                <field name="formato"/>
                <filter string="Borrador" name="filter_state_draft" domain="[('state', '=', 'draft')]"/> <!-- filtro para mostrar solo los torneos en estado borrador -->
                <filter string="Inscripciones Abiertas" name="filter_state_open" domain="[('state', '=', 'open')]"/> <!-- filtro para mostrar solo los torneos con inscripciones abiertas -->
                <filter string="En Curso" name="filter_state_ongoing" domain="[('state', '=', 'ongoing')]"/> <!-- filtro para mostrar solo los torneos en curso -->
                <filter string="Finalizado" name="filter_state_done" domain="[('state', '=', 'done')]"/> <!-- filtro para mostrar solo los torneos finalizados -->
                <separator/>
                <filter string="Con Videojuego" name="filter_videojuego_set" domain="[('videojuego_id', '!=', False)]"/> <!-- filtro para mostrar solo los torneos que tienen un videojuego asignado -->
                <filter string="Agrupar por Videojuego" name="group_by_videojuego" context="{'group_by': 'videojuego_id'}"/> <!-- filtro para agrupar los torneos por videojuego -->
                <separator/>
                <filter string="Liga" name="filter_formato_league" domain="[('formato', '=', 'league')]"/> <!-- filtro para mostrar solo los torneos con formato de liga -->
                <filter string="Elim. Directa" name="filter_formato_direct" domain="[('formato', '=', 'direct')]"/> <!-- filtro para mostrar solo los torneos con formato de eliminación directa -->
                <filter string="Doble Elim." name="filter_formato_double" domain="[('formato', '=', 'double')]"/> <!-- filtro para mostrar solo los torneos con formato de doble eliminación -->
            </search>
        </field>
    </record>

    <!-- Estas son las distintas acciones para cambiar entre los tipos de vistas-->
    <record id="action_esports_tournament" model="ir.actions.act_window"> <!-- ir.actions.act_window indica a odoo que lo que estamos haciendo es una acción de ventana-->
        <field name="name">Torneos</field> <!--nombre de la acción que aparecerá en el menú-->
        <field name="res_model">esports.tournament</field> <!--indicamos el modelo al que se refiere la acción-->
        <field name="view_mode">kanban,list,form</field> <!--indicamos los modos de vista disponibles-->
        <field name="search_view_id" ref="view_esports_tournament_search"/> <!--referenciamos la vista de búsqueda personalizada-->
    </record>

    <record id="action_esports_tournament_kanban_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_esports_tournament_kanban"/>
        <field name="act_window_id" ref="action_esports_tournament"/>
    </record>

    <record id="action_esports_tournament_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_tournament_list"/>
        <field name="act_window_id" ref="action_esports_tournament"/>
    </record>

    <record id="action_esports_tournament_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_tournament_form"/>
        <field name="act_window_id" ref="action_esports_tournament"/>
    </record>
</odoo>