<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vistas base del modelo esports.standing (clasificaciones). -->

    <!-- Vista de lista para ranking final por torneo/participante. -->
    <record id="view_esports_standing_list" model="ir.ui.view"> <!-- ir.ui.view indica a odoo que lo que estamos haciendo es una vista-->
        <field name="name">esports.standing.list</field>
        <field name="model">esports.standing</field>
        <field name="arch" type="xml">
            <list string="Clasificaciones">
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="posicion_final"/>
                <field name="factura_id"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario para las clasificaciones -->
    <record id="view_esports_standing_form" model="ir.ui.view">
        <field name="name">esports.standing.form</field>
        <field name="model">esports.standing</field>
        <field name="arch" type="xml">
            <form string="Clasificación">



            <!-- Botones de acción en el encabezado -->
                <header>
                    <button name="action_generate_prize_invoice" type="object" string="Generar factura de premio" class="oe_highlight" invisible="factura_id != False"/> <!-- El botón solo se muestra si no hay una factura asociada -->
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="torneo_id"/>
                            <field name="participante_id"/>
                        </group>
                        <group>
                            <field name="posicion_final"/>
                            <field name="factura_id"/>
                        </group>
                    </group>



                    <!-- Campos calculados -->
                    <group>
                        <field name="partidas_jugadas" readonly="1"/>
                        <field name="partidas_ganadas" readonly="1"/>
                        <field name="partidas_perdidas" readonly="1"/>
                        <field name="puntos_acumulados" readonly="1"/>
                        <field name="premio_obtenido" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista de búsqueda para filtrar clasificaciones. -->
    <record id="view_esports_standing_search" model="ir.ui.view">
        <field name="name">esports.standing.search</field>
        <field name="model">esports.standing</field>
        <field name="arch" type="xml">
            <search string="Buscar Clasificaciones">
                <field name="torneo_id"/>
                <field name="participante_id"/>
                <field name="posicion_final"/>
            </search>
        </field>
    </record>

    <!-- Estas son las distintas acciones para cambiar entre los tipos de vistas-->
    <record id="action_esports_standing" model="ir.actions.act_window"> <!-- ir.actions.act_window indica a odoo que lo que estamos haciendo es una acción de ventana-->
        <field name="name">Clasificaciones</field> <!--nombre de la acción que aparecerá en el menú-->
        <field name="res_model">esports.standing</field> <!--indicamos el modelo al que se aplicará la acción-->
        <field name="view_mode">list,form</field> <!--indicamos los modos de vista disponibles-->
        <field name="search_view_id" ref="view_esports_standing_search"/> <!--referenciamos la vista de búsqueda personalizada para clasificaciones-->
    </record>

    <record id="action_esports_standing_list_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_esports_standing_list"/>
        <field name="act_window_id" ref="action_esports_standing"/>
    </record>

    <record id="action_esports_standing_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_esports_standing_form"/>
        <field name="act_window_id" ref="action_esports_standing"/>
    </record>
</odoo>